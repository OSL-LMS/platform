# Copia este archivo a .env.local y rellena los valores.
# Todas estas claves viven SOLO en el servidor — nunca con prefijo NEXT_PUBLIC_.

# Clave de la API de Anthropic (tutor IA). Solo servidor.
ANTHROPIC_API_KEY=sk-ant-...

# Cadena de conexión a la Postgres. En Railway la inyecta el plugin de Postgres
# automáticamente; en local apunta a tu base de datos de desarrollo.
DATABASE_URL=postgres://usuario:password@localhost:5432/tutor

# Secreto de Auth.js para firmar/cifrar sesiones y tokens. Genera uno con:
#   npx auth secret    (o: openssl rand -base64 33)
AUTH_SECRET=reemplaza-con-un-secreto-aleatorio

# Clave de la API de Resend para enviar el magic link (enlace de acceso).
# Auth.js la detecta como AUTH_RESEND_KEY; aceptamos también RESEND_API_KEY.
AUTH_RESEND_KEY=re_...

# PostHog (telemetría del embudo: registro → primer mensaje → pago).
# Es la clave de PROYECTO (phc_...), no una personal. Si falta, la telemetría
# es un no-op silencioso: la app funciona igual. Solo servidor — el embudo se
# instrumenta con posthog-node, no hay posthog-js en el navegador.
POSTHOG_API_KEY=phc_...
# US: https://us.i.posthog.com (por defecto) · EU: https://eu.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com
